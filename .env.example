# Img2Video Environment Configuration
# Copy this file to .env and update the values

# AI API Configuration (Required)
ANTHROPIC_BASE_URL=https://your-ai-api-endpoint.com
ANTHROPIC_AUTH_TOKEN=your-auth-token-here

# Security
SECRET_KEY=your-super-secret-key-change-in-production

# Public URL (Required - for Kling API video source image access)
PUBLIC_BASE_URL=http://localhost:8103  # Change to your public server URL in production

# Email SMTP Configuration (Optional - for email verification)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=your-email@example.com
SMTP_USE_TLS=true

# Database (Optional - defaults are set for development)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/img2video

# Redis (Optional - defaults are set for development)
# REDIS_URL=redis://redis:6379/0

# MinIO (Optional - defaults are set for development)
# MINIO_ENDPOINT=minio:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
